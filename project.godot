[layer_names]

3d_render/layer_19="Shutters"
3d_render/layer_20="UI_Elements"
3d_physics/layer_1="Environment"
3d_physics/layer_2="Interactions "
3d_physics/layer_3="Entities"
3d_physics/layer_4="Snappable"

[physics]

3d/run_on_separate_thread=true
3d/physics_engine="Jolt Physics"

[rendering]

textures/vram_compression/import_etc2_astc=true
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=1
global_illumination/gi/use_half_resolution=true
shading/overrides/force_lambert_over_burley=true
environment/ssao/quality=1
environment/ssil/quality=1
anti_aliasing/screen_space_roughness_limiter/enabled=false
environment/subsurface_scattering/subsurface_scattering_quality=0
global_illumination/sdfgi/probe_ray_count=3
global_illumination/sdfgi/frames_to_converge=1
global_illumination/sdfgi/frames_to_update_lights=0
environment/volumetric_fog/use_filter=0
anti_aliasing/quality/screen_space_aa=1
occlusion_culling/use_occlusion_culling=true
