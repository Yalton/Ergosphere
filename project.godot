[layer_names]

3d_render/layer_20="UI_Elements"
3d_physics/layer_1="Environment"
3d_physics/layer_2="Interactions "
3d_physics/layer_3="Entities"
3d_physics/layer_4="Snappable"

[physics]

3d/run_on_separate_thread=true
3d/physics_engine="Jolt Physics"

[rendering]

global_illumination/sdfgi/probe_ray_count=3
global_illumination/sdfgi/frames_to_converge=1
global_illumination/sdfgi/frames_to_update_lights=0
occlusion_culling/use_occlusion_culling=true
