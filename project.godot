; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Ergosphere"
config/description="Does this show up in exports?"
config/version="0.18"
run/main_scene="uid://b2xc4entjfn1n"
config/features=PackedStringArray("4.4", "C#", "Forward Plus")
run/max_fps=160
boot_splash/image="uid://cy1a2f1ctbivh"
config/icon="uid://cn6owvke6ocl1"
config/macos_native_icon="uid://cn6owvke6ocl1"
config/windows_native_icon="res://Icon.ico"

[audio]

general/text_to_speech=true

[autoload]

DebugLogger="*res://addons/debug_manager/debug_logger.gd"
Audio="*res://Autoload/Audio.gd"
SettingsManager="*res://Autoload/SettingsManager.gd"
ButtonSoundManager="*res://Autoload/ButtonSoundManager/ButtonSoundManager.tscn"
TransitionManager="*res://Autoload/TransitionManager/transition_manager.tscn"
GameManager="*res://Autoload/GameManager/GameManager.tscn"
CommonUtils="*res://Autoload/Utilities.gd"
DevConsoleManager="*res://Autoload/DevConsoleManager/DevConsoleManager.tscn"

[debug]

gdscript/warnings/unused_variable=0
gdscript/warnings/unused_parameter=0
gdscript/warnings/unused_signal=0
gdscript/warnings/standalone_ternary=0
gdscript/warnings/incompatible_ternary=0
gdscript/warnings/integer_division=0

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="viewport"
window/vsync/vsync_mode=0

[dotnet]

project/assembly_name="Ergosphere"

[editor_plugins]

enabled=PackedStringArray("res://addons/debug_manager/plugin.cfg")

[file_customization]

folder_colors={
"res://Assets/": "orange",
"res://Autoload/": "yellow",
"res://Prefabs/": "teal",
"res://Scripts/": "blue",
"res://Subsystems/": "purple",
"res://addons/": "red",
"res://docs/": "green"
}

[global_group]

player=""
lights=""
power_lever=""
storage_wall=""
props=""
effects_manager=""
anomalous_hotspots=""
fx_spawn_points=""
window_lever=""
station=""
warp_destinations=""
door_wrappers=""

[gui]

theme/custom_font="uid://l6xcpy145etv"

